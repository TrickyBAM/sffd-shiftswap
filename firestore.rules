rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can read and write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Shifts are readable by anyone, but only writable by the poster
    match /shifts/{shiftId} {
      allow read: if true;
      allow write: if request.auth != null && request.resource.data.posterUid == request.auth.uid;
    }

    // Matched trades can be read and updated by either party involved
    match /matchedTrades/{tradeId} {
      allow read, write: if request.auth != null && (
        request.resource.data.posterUid == request.auth.uid ||
        request.resource.data.takerUid == request.auth.uid
      );
    }
  }
}